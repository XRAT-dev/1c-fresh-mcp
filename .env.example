# ============================================================
#  1C:Fresh MCP — пример переменных окружения
#  Скопируйте файл в .env и заполните реальными значениями.
#    cp .env.example .env
# ============================================================

# URL базы 1С:Fresh (без слеша на конце)
#   Пример:  https://msk1.1cfresh.com/a/ea/0000000
FRESH_BASE_URL=

# OData-пользователь и пароль
#   Создаётся в разделе «Пользователи» 1С:Fresh,
#   в настройках пользователя включите «Доступ к OData».
FRESH_USERNAME=odata.user
FRESH_PASSWORD=

# Проверка SSL-сертификата (True/False). По умолчанию True.
FRESH_VERIFY_SSL=True

# Таймаут HTTP-запросов, сек
FRESH_TIMEOUT=30

# Часовой пояс сервера 1С:Fresh в часах от UTC.
#   Новосибирск = 7, Москва = 3, Омск = 6 и т.д.
FRESH_TZ_OFFSET=7

# Ставка НДС по умолчанию для новых строк счёта.
#   Допустимые значения 2026 г.:
#     НДС22   — основная ставка (с 01.01.2025)
#     НДС20   — была основной до 2025, для переходных документов
#     НДС10   — льготная (еда, детские товары, книги, медикаменты)
#     НДС7    — УСН с доходом 250–450 млн ₽ (с 2025)
#     НДС5    — УСН с доходом 60–250 млн ₽ (с 2025)
#     НДС0    — экспорт (облагается по 0%, вычет входного НДС есть)
#     БезНДС  — освобождение (ст. 149 НК, вычета нет)
FRESH_VAT_DEFAULT=НДС22

# ── Опционально: печатная форма (pdf_invoice.py) ────────────
# Реквизиты банка поставщика — попадают в шапку PDF
PDF_BANK_NAME=
PDF_BANK_BIK=
PDF_BANK_CORR_ACC=
PDF_BANK_SETTLEMENT_ACC=

# Подпись в блоке «Предприниматель / …»
PDF_SIGNER_TITLE=Руководитель
PDF_SIGNER_NAME=

# Путь к PNG-баннеру для электронного варианта счёта (необязательно)
PDF_BANNER_PATH=
